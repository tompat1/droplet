{
  "name": "droplet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generateAssets.cjs",
    "dev": "vite",
    "prebuild": "node scripts/generateAssets.cjs",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "cf:deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute droplet-prod --local --file=./migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute droplet-prod --remote --file=./migrations/0001_initial.sql",
    "db:migrate:roles:local": "wrangler d1 execute droplet-prod --local --file=./migrations/0002_user_roles.sql",
    "db:migrate:roles:remote": "wrangler d1 execute droplet-prod --remote --file=./migrations/0002_user_roles.sql",
    "db:migrate:avatar:local": "wrangler d1 execute droplet-prod --local --file=./migrations/0003_user_avatar.sql",
    "db:migrate:avatar:remote": "wrangler d1 execute droplet-prod --remote --file=./migrations/0003_user_avatar.sql",
    "db:migrate:usage:local": "wrangler d1 execute droplet-prod --local --file=./migrations/0004_generation_usage.sql",
    "db:migrate:usage:remote": "wrangler d1 execute droplet-prod --remote --file=./migrations/0004_generation_usage.sql",
    "db:migrate:canvas-assets:local": "wrangler d1 execute droplet-prod --local --file=./migrations/0005_canvas_assets.sql",
    "db:migrate:canvas-assets:remote": "wrangler d1 execute droplet-prod --remote --file=./migrations/0005_canvas_assets.sql",
    "db:migrate:site-content:local": "wrangler d1 execute droplet-prod --local --file=./migrations/0006_site_content.sql",
    "db:migrate:site-content:remote": "wrangler d1 execute droplet-prod --remote --file=./migrations/0006_site_content.sql"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@xyflow/react": "^12.11.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "wrangler": "^4.111.0"
  }
}
